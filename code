import java.util.ArrayList;
import java.util.LinkedHashSet;

class Train {
    private ArrayList<Bogie> bogies = new ArrayList<>();
    private LinkedHashSet<String> bogieIds = new LinkedHashSet<>();

    // Add bogie
    public void addBogie(Bogie bogie) {

        if (bogieIds.contains(bogie.id)) {
            System.out.println(" Duplicate ID not allowed: " + bogie.id);
            return;
        }

        bogies.add(bogie);
        bogieIds.add(bogie.id);

        System.out.println(" Bogie added: " + bogie.id);
    }

    // Display insertion order IDs
    public void displayInsertionOrder() {
        System.out.println("\n--- Bogie IDs (Insertion Order) ---");
        for (String id : bogieIds) {
            System.out.println(id);
        }
    }

    // Display full bogie details
    public void displayBogies() {
        System.out.println("\n--- Train Composition ---");
        for (Bogie b : bogies) {
            b.displayDetails();
        }
    }
}
