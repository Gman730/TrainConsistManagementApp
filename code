import java.util.ArrayList;
import java.util.HashSet;

class Train {
    private ArrayList<Bogie> bogies = new ArrayList<>();
    private HashSet<String> bogieIds = new HashSet<>();

    // Add bogie with uniqueness enforcement
    public void addBogie(Bogie bogie) {

        if (bogieIds.contains(bogie.id)) {
            System.out.println(" Duplicate Bogie ID not allowed: " + bogie.id);
            return;
        }

        bogies.add(bogie);
        bogieIds.add(bogie.id);

        System.out.println(" Bogie added: " + bogie.id);
    }

    // Remove bogie safely
    public void removeBogie(String id) {
        for (int i = 0; i < bogies.size(); i++) {
            if (bogies.get(i).id.equals(id)) {
                bogies.remove(i);
                bogieIds.remove(id);
                System.out.println(" Bogie removed: " + id);
                return;
            }
        }
        System.out.println(" Bogie not found: " + id);
    }

    // Display consist
    public void displayBogies() {
        System.out.println("\n--- Train Composition ---");
        for (Bogie b : bogies) {
            b.displayDetails();
        }
    }
}
