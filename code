import java.util.ArrayList;
import java.util.HashSet;

class Train {
    private ArrayList<Bogie> bogies = new ArrayList<>();
    private HashSet<String> bogieIds = new HashSet<>();

    // Add bogie with uniqueness check
    public void addBogie(Bogie b) {

        if (bogieIds.contains(b.id)) {
            System.out.println(" Duplicate Bogie ID not allowed: " + b.id);
            return;
        }

        bogies.add(b);
        bogieIds.add(b.id);

        System.out.println(" Bogie added successfully: " + b.id);
    }

    // Remove bogie and update Set
    public void removeBogie(String id) {

        for (Bogie b : bogies) {
            if (b.id.equals(id)) {
                bogies.remove(b);
                bogieIds.remove(id);
                System.out.println("🗑️ Bogie removed: " + id);
                return;
            }
        }

        System.out.println(" Bogie not found: " + id);
    }

    // Display all bogies
    public void displayBogies() {
        System.out.println("\n--- Train Composition ---");

        for (Bogie b : bogies) {
            b.displayDetails();
        }
    }
}
